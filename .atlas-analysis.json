  "keyFeatures": [
    "Real-time table availability checking with 1-hour intervals",
    "SMS verification for customer reservations via Firebase Auth",
    "Multi-zone table management (Terrace, Salon, Garden, Bar, VIP)",
    "Email notifications for confirmations and cancellations",
    "Business owner admin panel with authentication",
    "Configurable business hours and reservation rules",
    "Clean Architecture with Flutter BLoC state management",
    "Firebase backend with Firestore and Cloud Functions"
  ],
  "publicApiSurface": [
    "CrearReserva.ejecutar() - Create a new reservation with validation",
    "CancelarReserva.ejecutar() - Cancel an existing reservation",
    "ObtenerReserva.ejecutar() - Get all reservations for a customer",
    "ReservaRepositorio.mesaDisponible() - Check table availability",
    "MesaRepositorio.buscarMesaDisponibleEnZona() - Find available tables by zone",
    "NegocioRepositorio.autenticarNegocio() - Authenticate business owner",
    "ServicioVerificacionCliente.enviarCodigoSMS() - Send SMS verification code",
    "ServicioEmail.enviarReservaConfirmada() - Send confirmation email",
    "HorarioAperturaRepositorio.estaAbiertoEn() - Check if restaurant is open",
    "DisponibilidadCubit - State management for availability checking",
    "MisReservasCubit - State management for customer reservations",
    "PantallaDuenoCubit - State management for business owner panel"
  ]
}
